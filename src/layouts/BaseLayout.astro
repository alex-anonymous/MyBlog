---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "一个个人网站和写作空间。" } = Astro.props;
const siteTitle = "MyBlog";
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">MyBlog</a>
      <nav aria-label="主导航">
        <a href="/posts/">文章</a>
        <a href="/about/">关于</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Built with Astro.</p>
    </footer>
    <script>
      import mermaid from "mermaid";

      mermaid.initialize({
        startOnLoad: false,
        securityLevel: "strict",
        theme: "base",
        themeVariables: {
          background: "#ffffff",
          primaryColor: "#f8f6f1",
          primaryTextColor: "#1c1b18",
          primaryBorderColor: "#ded8ce",
          lineColor: "#68645d",
          secondaryColor: "#ecf7f3",
          tertiaryColor: "#fff7ed",
          fontFamily:
            "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif"
        }
      });

      const renderMermaidBlocks = async () => {
        const blocks = document.querySelectorAll(
          'pre[data-language="mermaid"] > code, pre > code.language-mermaid, pre > code.lang-mermaid'
        );

        for (const [index, block] of [...blocks].entries()) {
          const source = block.textContent ?? "";
          const wrapper = document.createElement("div");
          wrapper.className = "mermaid-diagram";

          try {
            const { svg } = await mermaid.render(`mermaid-${index}`, source);
            wrapper.innerHTML = svg;
          } catch (error) {
            wrapper.classList.add("mermaid-diagram-error");
            wrapper.textContent = source;
            console.error("Failed to render Mermaid diagram", error);
          }

          block.parentElement?.replaceWith(wrapper);
        }
      };

      renderMermaidBlocks();
    </script>
  </body>
</html>
